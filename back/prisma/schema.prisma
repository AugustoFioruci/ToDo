generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  events    Event[]
}

model Event {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean         @default(false)

  recurrence  RecurrenceType  @default(NONE)
  interval    Int?            // ex: a cada 2 semanas
  repeatUntil DateTime?       // data limite da repetição

  createdAt   DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id])
  userId      Int
}
